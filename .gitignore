# https://git-scm.com/docs/gitignore

# Build
/dist/
/build/

# Cache
.cache/
.coverage*
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Editor
/.idea/
/.vscode/
.ipynb_checkpoints/

# Environs
.env
/.venv/

# Project
/mlruns/*
/outputs/*
!**/.gitkeep
/tests/temp/*

# Archive (private — not for remote)
/archive/

# Data (Strictly Ignored)
/data/*
!data/minio/
!data/chroma/
!data/.gitkeep
!data/raw/
/data/raw/*
!data/raw/xT_grid.csv

# Docker volumes
/data_lake/
/postgres_data/

# Logs
/ops/dagster_home/logs/
/ops/dagster_home/storage/
/ops/dagster_home_local/.telemetry/
/ops/dagster_home_local/history/
/ops/dagster_home_local/schedules/
/ops/dagster_home_local/storage/
/logs/
.tmp_dagster_home*/

# AI tooling
/agent-os/

# Docs (private — engineering diary, architecture notes)
/docs/*
!/docs/assets/

# Python
*.py[cod]
__pycache__/
*.duckdb

# Claude Code (private — not for remote)
.claude/

# OS
.DS_Store
